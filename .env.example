# Local Postgres (no pooler) — set both to the same value:
DATABASE_URL="postgresql://ainews:ainews_dev_password@localhost:5432/ainews?schema=public"
DIRECT_URL="postgresql://ainews:ainews_dev_password@localhost:5432/ainews?schema=public"

# Supabase (pooled) — DATABASE_URL is the transaction-mode pooler (:6543),
# DIRECT_URL is the session-mode pooler (:5432), used only for migrations:
# DATABASE_URL="postgresql://postgres.xxxxxxxxxxxx:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.xxxxxxxxxxxx:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"
